generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  VIEWER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         Role       @default(STAFF)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model DataSource {
  id               String    @id @default(cuid())
  name             String
  businessOwner    String?
  businessUnit     String?
  format           String
  location         String?
  accessMethod     String?
  refreshMethod    String?
  refreshFrequency String?
  screenshotNote   String?
  status           String    @default("unknown")
  lastSyncAt       DateTime?
  lastSyncStatus   String?
  syncCostCents    Int       @default(0)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  syncJobs         SyncJob[]
}

model SyncJob {
  id               String     @id @default(cuid())
  dataSourceId     String
  dataSource       DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  status           String
  trigger          String     @default("manual")
  errorCode        String?
  message          String?
  recordsProcessed Int?
  startedAt        DateTime   @default(now())
  finishedAt       DateTime?

  @@index([dataSourceId, startedAt])
}

model AdminAlert {
  id        String   @id @default(cuid())
  level     String   @default("warning")
  source    String?
  message   String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([readAt])
}

model BorrowerCaseNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String?
  authorName String?
  note       String
  createdAt  DateTime @default(now())

  @@index([customerId, createdAt])
}

model BorrowerAttachment {
  id          String   @id @default(cuid())
  customerId  String
  label       String
  url         String
  uploadedBy  String?
  uploadedAt  DateTime @default(now())

  @@index([customerId, uploadedAt])
}

model BorrowerWorkflow {
  id          String   @id @default(cuid())
  customerId  String   @unique
  status      String   @default("new")
  owner       String?
  dueDate     DateTime?
  reviewNotes String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([status, updatedAt])
}

model TEInquiryCostLog {
  id          String   @id @default(cuid())
  customerId  String?
  idNumber    String?
  query       String?
  userId      String?
  userEmail   String?
  costCents   Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([customerId, createdAt])
}

model CustomerRecord {
  id                 String   @id
  hkid               String
  name               String
  rawMobile          String
  status             String
  loanType           String
  applicationNumber  String
  loanNumber         String
  applyDate          String
  partakerType       String
  blacklistFlag      Boolean  @default(false)
  sourceSystem       String
  age                Int
  job                String
  companyUnit        String
  profileJson        Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([hkid])
  @@index([name])
}
