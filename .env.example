# OpenAI (server-side only)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Signed session cookie (required in production: at least 32 random bytes as string).
# Generate: openssl rand -hex 32
SESSION_SECRET=

# Portal login password.
# Development: defaults to "deview-demo" if unset.
# Production: required, minimum 16 characters.
PORTAL_DEMO_PASSWORD=deview-demo
