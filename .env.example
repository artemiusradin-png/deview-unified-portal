# Single access code for the portal (login + session signing).
# Production (Vercel): required, at least 8 characters. Name must be PORTAL_ACCESS_CODE.
# Local: optional; defaults to deview-demo if unset.
PORTAL_ACCESS_CODE=deview-demo

# OpenAI (server-side only) — for AI summaries
OPENAI_API_KEY=
