# OpenAI (server-side only)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Signed session cookie (required in production: value must be 32+ characters).
# Vercel: name must be exactly SESSION_SECRET (all caps). Generate: openssl rand -hex 32
SESSION_SECRET=

# Portal login password.
# Development: defaults to "deview-demo" if unset.
# Production: required, minimum 16 characters.
PORTAL_DEMO_PASSWORD=deview-demo
