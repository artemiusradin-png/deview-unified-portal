# Optional: separate JWT signing key (≥32 chars). If unset, signing uses a key derived from PORTAL_ACCESS_CODE.
# AUTH_SECRET=

# PostgreSQL for customer records, audit, admin (optional — login is access-code only unless you extend the app).
# When set, search/profile use Prisma first; otherwise mock data and/or Supabase (below).
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deview_portal

# Optional: comma-separated IPv4 addresses or CIDRs (e.g. 203.0.113.0/24). Empty = allow all.
# ALLOWED_IP_CIDRS=

# Access-code login when DATABASE_URL is not set (demo / legacy).
# Production without DB: required, 8+ characters. Exact name PORTAL_ACCESS_CODE.
PORTAL_ACCESS_CODE=deview-demo

# Seed script defaults (override when running npm run db:seed)
# SEED_ADMIN_EMAIL=admin@deviewai.local
# SEED_ADMIN_PASSWORD=ChangeMeAdmin!1
# SEED_STAFF_EMAIL=staff@deviewai.local
# SEED_STAFF_PASSWORD=ChangeMeStaff!1
# SEED_VIEWER_EMAIL=viewer@deviewai.local
# SEED_VIEWER_PASSWORD=ChangeMeViewer!1

# OpenAI (server-side only) — AI summaries and assistant
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Supabase REST — optional connector when DATABASE_URL is unset or Prisma fails over.
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
# SUPABASE_PORTAL_TABLE=portal_customer_profiles
